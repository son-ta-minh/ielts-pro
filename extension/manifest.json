{
  "manifest_version": 3,
  "name": "Mini Study Buddy",
  "version": "1.0",
  "description": "Mini Study Buddy bridge for Full StudyBuddy interactive mode",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "https://127.0.0.1:3000/*",
    "https://firestore.googleapis.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
